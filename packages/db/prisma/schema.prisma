generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  user
  assistant
  system
}

enum OrderType {
  pickup
  delivery
  reservation
}

enum OrderStatus {
  draft
  confirmed
  cancelled
}

model AgentSession {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  roomName  String    @unique
  messages  Message[]
  memories  MemoryChunk[]
  orders    Order[]
}

model Message {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  sessionId String
  role      MessageRole
  content   String

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model MemoryChunk {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  sessionId String?
  content   String
  metadata  Json?

  session    AgentSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  embeddings MemoryEmbedding[]

  @@index([sessionId, createdAt])
}

// Embedding dimension for OpenAI `text-embedding-3-small` is 1536.
// We store it as a `vector(1536)` column via pgvector.
model MemoryEmbedding {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  chunkId   String
  model     String

  // Requires pgvector extension.
  embedding Unsupported("vector(1536)")

  chunk MemoryChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([chunkId])
}

model Customer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String?
  phoneE164   String   @unique
  preferences Json?

  orders      Order[]
}

model MenuItem {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Stable identifier for imports/tooling (e.g. "pepperoni_pizza").
  code        String   @unique

  name        String
  category    String?
  description String?

  // Store money as integer cents to avoid float rounding.
  priceCents  Int

  isAvailable Boolean  @default(true)
  prepTimeMin Int?

  orderItems  OrderItem[]

  @@index([name])
  @@index([category])
}

model Order {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  type         OrderType
  status       OrderStatus @default(draft)

  // Optional link to the voice session / LiveKit room session.
  sessionId    String?
  session      AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  deliveryAddress      String?
  specialInstructions  String?

  subtotalCents Int?
  taxCents      Int?
  totalCents    Int?

  etaMinutes   Int?

  items        OrderItem[]

  @@index([createdAt])
  @@index([status])
  @@index([type])
  @@index([sessionId])
  @@index([customerId])
}

model OrderItem {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId  String?
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  // Snapshot fields (so historical orders survive menu changes).
  name        String
  unitPriceCents Int?

  quantity    Int
  modifiers   Json?
  notes       String?

  @@index([orderId])
  @@index([menuItemId])
}

